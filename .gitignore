# OS
.DS_Store
Thumbs.db

# Python
.venv/
__pycache__/
*.pyc
*.pyo

# Node (caso projetos filhos usem)
node_modules/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Outputs gerados por sessão (artefatos de kickoff não versionados)
skills/outputs/*
!skills/outputs/ARCHITECTURE.md
!skills/outputs/PROJECT_BRIEF.md
!skills/outputs/ROADMAP.md

# Cache de runtime
skills/cache/

# pnpm local store (nunca versionar)
.pnpm-store/

# --- Repo hygiene (ver skills/flows/repo-hygiene.md) ---

# Documentação interna do mantenedor (não vai para o repositório público)
docs/private/

# Fixtures e testes de execução local
_lab/

# Relatórios QA (projetos filhos e sessões locais)
qa/reports/

# Build / artefatos compilados
dist/
build/
.next/
*.tsbuildinfo

# Ambiente local
.env
.env.*
!.env.example
