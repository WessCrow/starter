{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "starter://runtime/schema/_meta.schema.json",
  "title": "RuntimeMeta",
  "type": "object",
  "properties": {
    "v": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+(\\.[0-9]+)?$" },
    "updated": { "type": "string", "format": "date" }
  },
  "required": ["v", "updated"],
  "additionalProperties": true
}
