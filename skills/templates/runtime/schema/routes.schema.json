{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "starter://runtime/schema/routes.schema.json",
  "title": "RuntimeRoutes",
  "allOf": [{ "$ref": "_meta.schema.json" }],
  "type": "object",
  "properties": {
    "resolution": {
      "type": "object",
      "properties": {
        "order": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "max_skills": { "type": "integer", "minimum": 1 },
        "max_primary": { "type": "integer", "minimum": 1 },
        "max_secondary": { "type": "integer", "minimum": 0 },
        "load_skill_only_if": { "type": "string" },
        "remote_cache_before_execute": { "type": "boolean" },
        "score_threshold_remote": { "type": "number" }
      },
      "required": ["order"],
      "additionalProperties": false
    },
    "protocol": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "steps": { "type": "array", "items": { "type": "string" } },
        "never_execute_without_confirmation": { "type": "boolean" }
      },
      "required": ["name", "never_execute_without_confirmation"],
      "additionalProperties": false
    },
    "intents": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "primary": { "type": "string" },
          "fallback": { "type": "array", "items": { "type": "string" } },
          "secondary": { "type": "array", "items": { "type": "string" } },
          "prerequisite": { "type": "string" },
          "category": { "type": ["integer", "string"] },
          "governance": { "type": "string" },
          "skill": { "type": ["string", "null"] },
          "mandatory": { "type": "boolean" },
          "blocks_feature_done_without_pass": { "type": "boolean" },
          "protocol": { "type": "string" },
          "triggers": { "type": "array", "items": { "type": "string" } },
          "user_facing": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "structure_detection": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "linked_skills_status": { "type": "string" },
    "activation_matrix": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "squad": { "type": "array", "items": { "type": "string" } },
          "steps": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["squad", "steps"],
        "additionalProperties": false
      }
    }
  },
  "required": ["resolution", "protocol", "intents"],
  "additionalProperties": false
}
