{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "starter://runtime/schema/handoff.schema.json",
  "title": "RuntimeHandoff",
  "allOf": [{ "$ref": "_meta.schema.json" }],
  "type": "object",
  "properties": {
    "session": {
      "type": "object",
      "properties": {
        "last_completed": { "type": ["string", "null"] },
        "next_action": { "type": ["string", "null"] },
        "blocked": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "qa": {
      "type": "object",
      "properties": {
        "last_status": {
          "type": "string",
          "enum": ["pending", "pass", "fail", "skipped"]
        },
        "last_report_path": { "type": ["string", "null"] },
        "last_run_at": { "type": ["string", "null"] },
        "failures_open": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["last_status"],
      "additionalProperties": false
    },
    "feature": {
      "type": "object",
      "properties": {
        "id": { "type": ["string", "null"] },
        "sprint_contract_path": { "type": ["string", "null"] },
        "spec_path": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "user": {
      "type": "object",
      "properties": {
        "verified_in_browser": { "type": "boolean" },
        "verified_at": { "type": ["string", "null"] },
        "notes": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "review": {
      "type": "object",
      "properties": {
        "last_review_path": { "type": ["string", "null"] },
        "last_review_at": { "type": ["string", "null"] },
        "reviews_since_improvement_sprint": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "context_metrics": {
      "type": "object",
      "properties": {
        "last_session_at": { "type": ["string", "null"] },
        "files_loaded": {
          "type": "array",
          "items": { "type": "string" }
        },
        "files_loaded_count": { "type": "integer", "minimum": 0 },
        "estimated_tokens": { "type": "integer", "minimum": 0 },
        "context_limit_exceeded": { "type": "boolean" },
        "unnecessary_files": {
          "type": "array",
          "items": { "type": "string" }
        },
        "estimation_method": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "reminders": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "when": { "type": "string" },
          "action": { "type": "string" }
        },
        "required": ["id", "action"],
        "additionalProperties": false
      }
    }
  },
  "required": ["qa"],
  "additionalProperties": false
}
