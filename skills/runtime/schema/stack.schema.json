{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "starter://runtime/schema/stack.schema.json",
  "title": "RuntimeStack",
  "allOf": [{ "$ref": "_meta.schema.json" }],
  "oneOf": [
    {
      "title": "AppStack",
      "type": "object",
      "properties": {
        "frontend": { "type": "string", "minLength": 1 },
        "backend": { "type": ["string", "null"] },
        "bundler": { "type": "string" },
        "ui": { "type": "string" },
        "architecture": { "type": "string" },
        "language": { "type": "string" },
        "structure_skill": { "type": "string" }
      },
      "required": ["frontend"],
      "additionalProperties": false
    },
    {
      "title": "MetaRuntimeStack",
      "type": "object",
      "properties": {
        "type": { "type": "string", "minLength": 1 },
        "formats": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "resolution": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "paths": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "project_type": { "type": "string" },
        "structure": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "resolution_order": {
          "type": "array",
          "items": { "type": "string" }
        },
        "recommended_new_projects": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "required": ["type"],
      "additionalProperties": false
    }
  ]
}
